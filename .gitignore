# Data files — ignore everything *inside* data/ except the small
# manifest (and README) used for reproducibility. Note: we cannot use
# `data/` as the pattern because git refuses to re-include files
# whose parent directory is excluded.
data/**
!data/
!data/MANIFEST.json
!data/README.md
*.parquet
*.ods

# Results (generated)
results/

# Documentation (binary)
docs/*.pdf

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp
