\@writefile{toc}{\contentsline {section}{\numberline {11}Robustesse statistique avancée}{24}{section.11}\protected@file@percent }
\newlabel{sec:advanced_robustness}{{11}{24}{Robustesse statistique avancée}{section.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.1}Pourquoi un Sharpe ponctuel ne suffit pas}{24}{subsection.11.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.2}Intervalles de confiance bootstrap sur les 14 métriques}{25}{subsection.11.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Intervalles de confiance bootstrap à 95\,\% sur les 14 métriques standard. Block bootstrap stationnaire Politis--Romano (1994), $n_{\text  {boot}} = 3000$, longueur de bloc moyenne = 20~jours, \texttt  {seed=20260414}. Les métriques marquées en gras sont celles commentées dans le texte.}}{25}{table.caption.24}\protected@file@percent }
\newlabel{tab:robustness_bootstrap_ci}{{10}{25}{Intervalles de confiance bootstrap à 95\,\% sur les 14 métriques standard. Block bootstrap stationnaire Politis--Romano (1994), $n_{\text {boot}} = 3000$, longueur de bloc moyenne = 20~jours, \texttt {seed=20260414}. Les métriques marquées en gras sont celles commentées dans le texte}{table.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Graphique \emph  {forest plot} des six métriques principales. Le diamant orange marque la valeur observée sur la période complète, la barre bleue représente l'intervalle de confiance bootstrap à 95\,\%. L'essentiel~: la borne basse du Sharpe ($0.365$) est strictement positive, ce qui est la condition statistique minimale pour qu'une stratégie soit considérée comme ayant un \emph  {edge} non-nul avec un niveau de confiance de 95\,\%.}}{26}{figure.caption.25}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Distribution complète des 3000~Sharpe ratios bootstrap. La ligne orange matérialise la valeur observée ($0.966$), les deux lignes vertes pointillées matérialisent les bornes 2.5~\% et 97.5~\% ($[0.365,\ 1.546]$). La distribution est légèrement asymétrique à droite, cohérente avec les queues épaisses des rendements FX.}}{26}{figure.caption.26}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Deux zones de vigilance identifiées.}{27}{paragraph*.27}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.3}\emph  {Equity fan chart} --- 300 trajectoires bootstrap alternatives}{27}{subsection.11.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \emph  {Fan chart} bootstrap --- 300~trajectoires alternatives compressées en bandes de percentiles. La courbe observée (bourgogne) reste dans la partie supérieure du fan à partir de 2023, cohérente avec la période qui a informé le design. Sur la fenêtre hors échantillon 2025-04$+$, la courbe observée \emph  {sort du fan P25--P75 vers le haut}~: le Sharpe OOS de $1.44$ dépasse la médiane bootstrap, confirmant que la stratégie n'est pas un artefact de l'échantillon d'entraînement.}}{27}{figure.caption.28}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.4}Tests d'\emph  {overfitting}}{28}{subsection.11.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Tests de correction d'\textit  {overfitting}. Tous les tests convergent vers un verdict favorable sur le portefeuille combiné. Références~: Bailey \& L\'opez~de~Prado~(2012, 2014, 2015), Harvey \& Liu~(2015).}}{28}{table.caption.29}\protected@file@percent }
\newlabel{tab:robustness_overfitting}{{11}{28}{Tests de correction d'\textit {overfitting}. Tous les tests convergent vers un verdict favorable sur le portefeuille combiné. Références~: Bailey \& L\'opez~de~Prado~(2012, 2014, 2015), Harvey \& Liu~(2015)}{table.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Distribution des 12\,870~logits CSCV. La ligne verticale orange matérialise le seuil logit~$= 0$ (au-dessus~: le vainqueur IS est au-dessus de la médiane OOS~; en-dessous~: overfitting manifeste). Le PBO de $0.305$ signifie que 30.5\,\% de la masse de la distribution est à gauche du seuil.}}{29}{figure.caption.30}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.5}Tests de supériorité prédictive --- Hansen SPA et Romano--Wolf StepM}{29}{subsection.11.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Tests de supériorité prédictive avec correction de \textit  {data snooping} sur les composantes individuelles. Hansen SPA~(2005) renvoie une p-value globale~; Romano--Wolf StepM~(2005) contrôle le FWER en renvoyant l'ensemble des stratégies dominantes.}}{29}{table.caption.31}\protected@file@percent }
\newlabel{tab:robustness_arch_tests}{{12}{29}{Tests de supériorité prédictive avec correction de \textit {data snooping} sur les composantes individuelles. Hansen SPA~(2005) renvoie une p-value globale~; Romano--Wolf StepM~(2005) contrôle le FWER en renvoyant l'ensemble des stratégies dominantes}{table.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces P-values du test de Hansen SPA (2005) sur les cinq composantes. Les trois bornes (basse, cohérente, haute) correspondent à trois estimateurs différents du \textit  {re-centering} de Hansen, la borne cohérente étant celle recommandée en pratique. La ligne pointillée orange matérialise le seuil $\alpha = 0.05$.}}{30}{figure.caption.32}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.6}Stabilité temporelle multi-métrique}{30}{subsection.11.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Stabilité temporelle des trois métriques de risque ajusté. Les trois courbes restent majoritairement positives sur 2019--2026, avec un creux visible en 2019 (cohérent avec le Sharpe walk-forward $-0.49$ documenté section~\ref {sec:in_sample}) et un pic en 2022 (cohérent avec le Sharpe walk-forward $+2.26$). La ligne pointillée verticale marque le début de la fenêtre hors échantillon.}}{31}{figure.caption.33}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.7}Verdict consolidé}{31}{subsection.11.7}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Verdict consolidé sur les tests de robustesse statistique. Six tests passent sans réserve~; un test (P95 du Max Drawdown bootstrap) est proche de la limite utilisateur avec environ 2~pp de marge, déjà mitigé par la réserve cash 30\,\% recommandée en section~\ref {sec:limitations}.}}{31}{table.caption.34}\protected@file@percent }
\newlabel{tab:robustness_verdict_summary}{{13}{31}{Verdict consolidé sur les tests de robustesse statistique. Six tests passent sans réserve~; un test (P95 du Max Drawdown bootstrap) est proche de la limite utilisateur avec environ 2~pp de marge, déjà mitigé par la réserve cash 30\,\% recommandée en section~\ref {sec:limitations}}{table.caption.34}{}}
\@writefile{toc}{\contentsline {section}{\numberline {12}Rejeu de scénarios historiques}{32}{section.12}\protected@file@percent }
