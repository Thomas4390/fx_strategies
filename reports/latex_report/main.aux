\@writefile{toc}{\contentsline {section}{\numberline {11}Robustesse statistique avancée}{25}{section.11}\protected@file@percent }
\newlabel{sec:advanced_robustness}{{11}{25}{Robustesse statistique avancée}{section.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.1}Pourquoi un Sharpe ponctuel ne suffit pas}{25}{subsection.11.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.2}Intervalles de confiance bootstrap sur les métriques}{25}{subsection.11.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Intervalles de confiance bootstrap à 95\,\% sur 13 métriques standard (Omega Ratio omis, mathématiquement identique à Profit Factor au niveau rendement). Métriques de risque affichées selon la convention usuelle (drawdown négatif, volatilité positive). La ligne Rendement total couvre la période complète du backtest et ne se compare pas directement à la colonne IS du Tableau~\ref {tab:metrics_summary}.}}{26}{table.caption.25}\protected@file@percent }
\newlabel{tab:robustness_bootstrap_ci}{{11}{26}{Intervalles de confiance bootstrap à 95\,\% sur 13 métriques standard (Omega Ratio omis, mathématiquement identique à Profit Factor au niveau rendement). Métriques de risque affichées selon la convention usuelle (drawdown négatif, volatilité positive). La ligne Rendement total couvre la période complète du backtest et ne se compare pas directement à la colonne IS du Tableau~\ref {tab:metrics_summary}}{table.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces \emph  {Forest plot} des cinq métriques principales. Le diamant orange marque la valeur observée, la barre bleue l'intervalle de confiance bootstrap à 95\,\%. La borne basse du Sharpe ($0.365$) est strictement positive, ce qui est la condition statistique minimale pour qu'une stratégie soit considérée comme ayant un \emph  {edge} non-nul avec un niveau de confiance de 95\,\%.}}{26}{figure.caption.26}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Distribution bootstrap du Sharpe ratio. La ligne orange matérialise la valeur observée ($0.97$), les deux lignes vertes pointillées matérialisent les bornes de l'intervalle de confiance à 95\,\% $[0.37,\ 1.55]$. La distribution est légèrement asymétrique à droite, cohérente avec les queues épaisses des rendements FX.}}{27}{figure.caption.27}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Deux zones de vigilance identifiées.}{27}{paragraph*.28}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.3}\emph  {Equity fan chart} --- trajectoires bootstrap alternatives}{27}{subsection.11.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces \emph  {Fan chart} bootstrap --- trajectoires alternatives compressées en bandes de percentiles. La courbe observée (bourgogne) reste dans la partie supérieure du fan à partir de 2023. Sur la fenêtre hors échantillon, la courbe observée \emph  {sort du fan P25--P75 vers le haut}~: le Sharpe OOS de $1.44$ dépasse la médiane bootstrap, confirmant que la stratégie n'est pas un artefact de l'échantillon d'entraînement.}}{28}{figure.caption.29}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.4}Tests d'\emph  {overfitting}}{28}{subsection.11.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Tests de correction d'\textit  {overfitting}. Tous les tests convergent vers un verdict favorable sur le portefeuille combiné. Références~: Bailey \& L\'opez~de~Prado~(2012, 2014, 2015), Harvey \& Liu~(2015).}}{28}{table.caption.30}\protected@file@percent }
\newlabel{tab:robustness_overfitting}{{12}{28}{Tests de correction d'\textit {overfitting}. Tous les tests convergent vers un verdict favorable sur le portefeuille combiné. Références~: Bailey \& L\'opez~de~Prado~(2012, 2014, 2015), Harvey \& Liu~(2015)}{table.caption.30}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Distribution des logits de validation croisée combinatoire. La ligne verticale orange matérialise le seuil au-dessus duquel le vainqueur in-sample est au-dessus de la médiane out-of-sample (en-dessous~: overfitting manifeste). Le PBO de $0.31$ signifie que 31\,\% de la masse de la distribution est à gauche du seuil.}}{29}{figure.caption.31}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.5}Tests de supériorité prédictive}{29}{subsection.11.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Tests de supériorité prédictive avec correction de \textit  {data snooping} sur les composantes individuelles. Hansen SPA~(2005) renvoie une p-value globale~; Romano--Wolf StepM~(2005) contrôle le FWER en renvoyant l'ensemble des stratégies dominantes.}}{30}{table.caption.32}\protected@file@percent }
\newlabel{tab:robustness_arch_tests}{{13}{30}{Tests de supériorité prédictive avec correction de \textit {data snooping} sur les composantes individuelles. Hansen SPA~(2005) renvoie une p-value globale~; Romano--Wolf StepM~(2005) contrôle le FWER en renvoyant l'ensemble des stratégies dominantes}{table.caption.32}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces P-values du test de supériorité prédictive sur les cinq composantes. Les trois bornes correspondent à trois estimateurs différents du re-centering, la borne cohérente étant celle recommandée en pratique. La ligne pointillée orange matérialise le seuil $\alpha = 0.05$.}}{30}{figure.caption.33}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.6}Stabilité temporelle multi-métrique}{30}{subsection.11.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Stabilité temporelle des trois métriques de risque ajusté. Les trois courbes restent majoritairement positives sur 2019--2026, avec un creux visible en 2019 et un pic en 2022. La ligne pointillée verticale marque le début de la fenêtre hors échantillon.}}{31}{figure.caption.34}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {11.7}Verdict consolidé}{31}{subsection.11.7}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {14}{\ignorespaces Verdict consolidé sur les tests de robustesse statistique. Six tests passent sans réserve~; un test (P95 du Max Drawdown bootstrap) est proche de la limite utilisateur avec environ 2~pp de marge, déjà mitigé par la réserve cash 30\,\% recommandée en section d'analyse des risques.}}{31}{table.caption.35}\protected@file@percent }
\newlabel{tab:robustness_verdict_summary}{{14}{31}{Verdict consolidé sur les tests de robustesse statistique. Six tests passent sans réserve~; un test (P95 du Max Drawdown bootstrap) est proche de la limite utilisateur avec environ 2~pp de marge, déjà mitigé par la réserve cash 30\,\% recommandée en section d'analyse des risques}{table.caption.35}{}}
