\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Métriques clés du portefeuille Apogée Invest sur les trois régimes d'évaluation. Les colonnes Bootstrap rapportent les percentiles P5/P95 d'un \emph  {block bootstrap} stationnaire sur la période in-sample. La colonne OOS démontre un Sharpe supérieur à l'IS, ce qui réfute empiriquement l'hypothèse d'overfitting majeur.}}{1}{table.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:metrics_summary}{{1}{1}{Métriques clés du portefeuille Apogée Invest sur les trois régimes d'évaluation. Les colonnes Bootstrap rapportent les percentiles P5/P95 d'un \emph {block bootstrap} stationnaire sur la période in-sample. La colonne OOS démontre un Sharpe supérieur à l'IS, ce qui réfute empiriquement l'hypothèse d'overfitting majeur}{table.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Courbes d'équité cumulative, base 100 au 1\textsuperscript  {er}~avril 2019, échelle logarithmique. Les trois courbes fines représentent les moteurs individuels \emph  {sans pondération de portefeuille ni ciblage de volatilité} (chacun à sa volatilité intrinsèque naturelle). La courbe épaisse bordeaux est le portefeuille combiné Apogée Invest après application des poids $80/10/10$ \emph  {et} de la couche de ciblage de volatilité (cible $\sigma ^\star = 28\,\%$, plafond de levier $12\times $). La différence de niveau entre les courbes fines et la courbe combinée reflète donc l'amplification par le levier, pas une quelconque supériorité intrinsèque du combiné. La ligne verticale pointillée marque le début de la fenêtre hors échantillon (1\textsuperscript  {er}~avril 2025).}}{2}{figure.caption.2}\protected@file@percent }
